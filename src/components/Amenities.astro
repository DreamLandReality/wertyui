---
import { resolveIconPaths } from '../utils/icons';

export interface Props {
  data: {
    sectionEyebrow?: string;
    sectionTitle?: string;
    items: Array<{
      icon: string;
      label: string;
      description: string;
    }>;
  };
}

const { data } = Astro.props;
---

<section class="py-24 border-t border-border" data-dr-section="amenities">
  <div class="max-w-7xl mx-auto px-8 md:px-12">
    {(data.sectionEyebrow || data.sectionTitle) && (
      <div class="mb-14">
        {data.sectionEyebrow && (
          <p class="text-[10px] uppercase tracking-[0.4em] text-muted mb-3" data-dr-field="sectionEyebrow">
            {data.sectionEyebrow}
          </p>
        )}
        {data.sectionTitle && (
          <h2 class="text-3xl md:text-4xl font-serif font-light" data-dr-field="sectionTitle">
            {data.sectionTitle}
          </h2>
        )}
      </div>
    )}

    <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-px bg-border" data-dr-list="items">
      {data.items.map((item, index) => (
        <div
          class="amenity-item bg-background hover:bg-surface p-8 md:p-10 transition-colors duration-300 group"
          data-dr-list-item
          data-dr-index={index}
        >
          <div class="mb-6 text-muted group-hover:text-primary transition-colors duration-300">
            <svg
              class="w-8 h-8 transition-transform duration-300 group-hover:scale-110"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
              stroke-width="1.5"
              stroke-linecap="round"
              stroke-linejoin="round"
              data-dr-field="icon"
            >
              {resolveIconPaths(item.icon).map((d) => (
                <path d={d} />
              ))}
            </svg>
          </div>
          <h3 class="text-sm font-sans font-medium uppercase tracking-[0.15em] text-primary mb-2" data-dr-field="label">
            {item.label}
          </h3>
          <p class="text-[13px] text-muted leading-relaxed" data-dr-field="description">
            {item.description}
          </p>
        </div>
      ))}
    </div>
  </div>
</section>
