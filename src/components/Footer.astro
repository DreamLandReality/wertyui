---
export interface Props {
  data: {
    copyright: string;
    branding?: string;
  };
}

const { data } = Astro.props;
---

<footer class="bg-primary text-primary-foreground/40 border-t border-primary-foreground/10 py-10 px-8 md:px-12" data-dr-section="footer">
  <div class="max-w-7xl mx-auto flex justify-center items-center text-[10px] uppercase tracking-[0.3em]">
    <div data-dr-field="copyright" data-dr-style="copyright">
      {data.copyright}
    </div>
  </div>
</footer>
