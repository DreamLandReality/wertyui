---
export interface Props {
  data: {
    sectionEyebrow?: string;
    sectionTitle?: string;
    items: Array<{
      name: string;
      photo?: string;
      text: string;
      rating: number;
    }>;
  };
}

const { data } = Astro.props;
const imgSrc = (path: string) => path?.startsWith('http') ? path : `/${path}`;
---

<section class="py-24 bg-surface border-t border-border" data-dr-section="testimonials">
  <div class="max-w-7xl mx-auto px-8 md:px-12">
    {(data.sectionEyebrow || data.sectionTitle) && (
      <div class="mb-14">
        {data.sectionEyebrow && (
          <p class="text-[10px] uppercase tracking-[0.4em] text-muted mb-3" data-dr-field="sectionEyebrow">
            {data.sectionEyebrow}
          </p>
        )}
        {data.sectionTitle && (
          <h2 class="text-3xl md:text-4xl font-serif font-light" data-dr-field="sectionTitle">
            {data.sectionTitle}
          </h2>
        )}
      </div>
    )}

    <div class="grid grid-cols-1 md:grid-cols-2 gap-px bg-border" data-dr-list="items">
      {data.items.map((item, index) => (
        <div class="bg-surface p-10 md:p-12" data-dr-list-item data-dr-index={index}>
          <!-- Stars -->
          <div class="flex gap-1 mb-6">
            {Array.from({ length: 5 }).map((_, i) => (
              <svg
                class={`w-3 h-3 ${i < item.rating ? 'text-primary' : 'text-border'} fill-current`}
                viewBox="0 0 20 20"
              >
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
              </svg>
            ))}
          </div>

          <!-- Quote -->
          <p class="text-base md:text-lg font-serif font-light text-primary leading-relaxed mb-8 italic" data-dr-field="text">
            &ldquo;{item.text}&rdquo;
          </p>

          <!-- Author -->
          <div class="flex items-center gap-4">
            {item.photo ? (
              <img
                src={imgSrc(item.photo)}
                alt={item.name}
                class="w-10 h-10 object-cover flex-shrink-0"
                data-dr-field="photo"
              />
            ) : (
              <div class="w-10 h-10 bg-border flex items-center justify-center flex-shrink-0">
                <span class="text-muted font-serif text-base">{item.name.charAt(0)}</span>
              </div>
            )}
            <div class="w-px h-8 bg-border"></div>
            <span class="text-[11px] uppercase tracking-[0.25em] text-primary" data-dr-field="name">
              {item.name}
            </span>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
