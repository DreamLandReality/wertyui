# ─── LOCAL DEVELOPMENT ONLY ──────────────────────────────────────────────────
# ⚠️  THIS FILE IS ONLY FOR RUNNING THE TEMPLATE LOCALLY ON YOUR MACHINE
# ⚠️  DEPLOYMENT DOES NOT USE THIS FILE - Admin panel injects values automatically
#
# To use:
#   1. Copy this file: cp .env.example .env
#   2. Run: npm run dev
#   3. Open: http://localhost:4321
#
# You only need this if you're developing the template itself.
# ─────────────────────────────────────────────────────────────────────────────

# Site URL for local development
SITE_URL=http://localhost:4321

# ─── Optional: Supabase (for testing contact forms locally) ─────────────────
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_ANON_KEY=your_anon_key
