# Generated from tooling/config/allowed-origins.config.js
# DO NOT EDIT MANUALLY - Changes will be overwritten on next build
# To add new admin panel domains, edit the config file and run: npm run build

/*
  Cache-Control: no-store
  X-Content-Type-Options: nosniff
  Content-Security-Policy: frame-ancestors 'self' http://localhost:3000 http://localhost:3001 http://127.0.0.1:3000 http://127.0.0.1:3001 https://localhost:3000 https://localhost:3001 https://admin-panel-mu-sand.vercel.app
  Referrer-Policy: strict-origin-when-cross-origin
  X-XSS-Protection: 1; mode=block

/defaults/*
  Cache-Control: public, max-age=86400

/*.css
  Cache-Control: public, max-age=31536000, immutable

/*.js
  Cache-Control: public, max-age=31536000, immutable

/sitemap-index.xml
  Cache-Control: public, max-age=3600
  Content-Type: application/xml; charset=utf-8
  Link: </sitemap-index.xml>; rel="sitemap"

/robots.txt
  Cache-Control: public, max-age=86400

/llms.txt
  Cache-Control: public, max-age=86400
  Content-Type: text/plain; charset=utf-8
